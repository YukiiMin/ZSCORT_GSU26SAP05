{
  "global": {
    "files": [
      "/src/**/*.abap"
    ]
  },
  "syntax": {
    "version": "v740sp05",
    "errorNamespace": "^(Z|Y)",
    "allowedNamespaces": [
      "^[+_]",
      "^(Z|Y)"
    ]
  },
  "rules": {
    "parser_error": true,
    "check_syntax": true,
    "undefined_methods": true,
    "implement_methods": true,
    "superclass_final": true,
    "interfaces_in_class_declaration": true,
    "friends_in_class": true,
    "local_class_naming": false,
    "check_no_handler_pragma": false
  },
  "expect": {},
  "depend": {},
  "uses": []
}